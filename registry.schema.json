{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "pie-extensions extension registry",
  "type": "object",
  "required": ["extensions"],
  "properties": {
    "extensions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "mirror-repo", "upstream-repo", "upstream-type", "packagist-name", "packagist-registered", "php-ext-name", "status", "added"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Short lowercase name, e.g. redis"
          },
          "mirror-repo": {
            "type": "string",
            "description": "pie-extensions/<name>"
          },
          "upstream-repo": {
            "type": "string",
            "description": "owner/repo on GitHub"
          },
          "upstream-type": {
            "type": "string",
            "enum": ["github"],
            "description": "Only github supported currently"
          },
          "packagist-name": {
            "type": "string",
            "description": "pie-extensions/<name>"
          },
          "packagist-registered": {
            "type": "boolean"
          },
          "php-ext-name": {
            "type": "string",
            "description": "The actual PHP extension name as reported by php -m"
          },
          "status": {
            "type": "string",
            "enum": ["active", "stale", "deprecated", "needs-packagist"]
          },
          "added": {
            "type": "string",
            "format": "date",
            "description": "YYYY-MM-DD"
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  }
}